# ===== DONNÉES SENSIBLES — NE JAMAIS POUSSER =====
data/raw/
*.xlsx
*.csv
*.sas7bdat
*.parquet
*.pkl
*.feather

# Exceptions : fichiers de config non sensibles
!data/raw/.gitkeep
!data/processed/.gitkeep

# Exception : chantier exploratoire (modèle qualitatif DORA, sorties NON sensibles)
!exploratory/*.xlsx
!exploratory/**/*.xlsx

# ===== PYTHON =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/
.eggs/

# ===== JUPYTER =====
.ipynb_checkpoints/
*.ipynb_checkpoints

# ===== IDE =====
.vscode/settings.json
.claude/settings.local.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ===== OUTPUTS VOLUMINEUX =====
# Les figures PNG du mémoire sont versionnées (référencées par memoire/main.tex).
outputs/figures/*.pdf
outputs/tables/*.xlsx

# ===== LATEX (mémoire) =====
memoire/tectonic
memoire/*.pdf
memoire/*.aux
memoire/*.bbl
memoire/*.bcf
memoire/*.blg
memoire/*.log
memoire/*.out
memoire/*.run.xml
memoire/*.toc

# ===== LOGS =====
*.log
logs/

# ===== ENV =====
.env
.env.local
config/secrets.yaml
